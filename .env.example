# NunezDev — example environment variables.
# Copy to .env.local and fill in real values. Anything prefixed NEXT_PUBLIC_
# is exposed to the browser at build time, so only put non-secret values here.

# ---------------------------------------------------------------------------
# Search engine site-verification codes (optional)
# ---------------------------------------------------------------------------
# Both vars only matter if you're using the "HTML meta tag" verification
# method. If empty, no meta tag is rendered (which is the correct behavior
# when verification happens elsewhere — see below). Don't fill in unless
# the method you used actually requires a meta tag.

# Google: ONLY needed if your GSC property is a "URL prefix" property
#   verified via the HTML tag method. If your property is a Domain
#   property (verified via a DNS TXT record at your registrar), leave
#   this empty — your site is already verified at the DNS layer.
#   GSC: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing: ONLY needed if you verified Bing Webmaster Tools via the
#   "Meta tag" method. If you imported the site from Google Search
#   Console (Bing inherits GSC's verification) or verified via DNS,
#   leave this empty.
#   Bing Webmaster: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_VERIFICATION=

# ---------------------------------------------------------------------------
# Cloudflare Turnstile — spam protection on public forms
# ---------------------------------------------------------------------------
# Used by /api/contact and /api/appointments to block bot submissions.
# Free tier covers up to 1M requests/month. If BOTH are unset, the widget
# is hidden and server-side verification is skipped (forms still work).
#
# Set up at https://dash.cloudflare.com/?to=/:account/turnstile
#   1. Create a site (managed challenge, invisible)
#   2. Add hostname: www.nunezdev.com (and nunezdev.com if no redirect)
#   3. Copy the Site Key into NEXT_PUBLIC_TURNSTILE_SITE_KEY (client-facing)
#   4. Copy the Secret Key into TURNSTILE_SECRET_KEY (server-only)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Google Ads API — campaign + keyword metrics for the leadgen "Ads" dashboard
# ---------------------------------------------------------------------------
# Powers /dashboard/leadgen/ads and the nightly cron
# /api/cron/leadgen-google-ads-sync. All five are server-only secrets. If any
# are unset the dashboard shows a "not connected" state and the cron no-ops.
# Full setup walkthrough is in the README under "Google Ads integration".
#
#   DEVELOPER_TOKEN     Google Ads UI → Tools & Settings → API Center
#                       (needs a Manager/MCC account; apply for Basic access)
#   CLIENT_ID/SECRET    Google Cloud console → APIs & Services → Credentials
#                       → OAuth client ID (Desktop app)
#   REFRESH_TOKEN       one-time OAuth consent for scope .../auth/adwords
#                       (see scripts/google-ads-oauth.mjs)
#   CUSTOMER_ID         the Ads account to query, digits only (1234567890)
#   LOGIN_CUSTOMER_ID   optional — the manager (MCC) id, only if querying
#                       through a manager account
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Shared bearer secret for the internal /api/keyword-volume endpoint, called by
# the leadgen pipeline to pull cached Keyword Planner search volume for outreach
# copy. Set the same value in the pipeline's KEYWORD_VOLUME_SECRET.
KEYWORD_VOLUME_SECRET=

# Twilio Messaging Service SID (MG...). OPTIONAL but recommended: when set,
# outbound SMS routes through the Messaging Service instead of the bare From
# number, so Twilio's Advanced Opt-Out engine sends the STOP/HELP confirmation
# replies (we can't send those ourselves — a post-STOP API send is blocked with
# error 21610). Requires Opt-Out Management enabled on the service in the
# Twilio Console. The number must be attached to the service.
TWILIO_MESSAGING_SERVICE_SID=

# ---------------------------------------------------------------------------
# Thumbtack Partner Platform API — associate phone numbers (caller ID / leads)
# ---------------------------------------------------------------------------
# Server-side client (src/lib/thumbtackApi.ts) using the OAuth2
# client-credentials grant against Thumbtack's Hydra token server. Each
# environment has its own hosts AND its own client credentials.
#
#   THUMBTACK_ENV          staging (default) | production
#   THUMBTACK_API_SCOPES   space-delimited scope(s). OPTIONAL — defaults to the
#                          associate-phone-numbers read+write scopes below. Only
#                          set to call other routes.
#   *_CLIENT_ID / SECRET   production credentials (also the staging fallback)
#   STAGING_*              staging credentials (preferred when ENV=staging)
THUMBTACK_ENV=staging
# Default when unset (from the OpenAPI spec's per-operation security):
#   supply::businesses/associate-phone-numbers.read supply::businesses/associate-phone-numbers.write
THUMBTACK_API_SCOPES=
THUMBTACK_CLIENT_ID=
THUMBTACK_CLIENT_SECRET=
THUMBTACK_STAGING_CLIENT_ID=
THUMBTACK_STAGING_CLIENT_SECRET=
