# NunezDev — example environment variables.
# Copy to .env.local and fill in real values. Anything prefixed NEXT_PUBLIC_
# is exposed to the browser at build time, so only put non-secret values here.

# ---------------------------------------------------------------------------
# Search engine site-verification codes (optional, but used by SEO)
# ---------------------------------------------------------------------------
# Google: get this from Google Search Console -> Settings -> Ownership
#   verification -> "HTML tag" method. Paste only the content="..." value.
#   Reference: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing: get this from Bing Webmaster Tools -> Site -> Configure My Site ->
#   Verify Ownership -> "Meta tag" method. Paste only the content="..." value.
#   Reference: https://www.bing.com/webmasters
NEXT_PUBLIC_BING_VERIFICATION=
